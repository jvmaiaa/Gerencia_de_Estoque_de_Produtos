# ========== SEGURANÇA - Nunca commitar arquivos sensíveis ==========
# Variáveis de ambiente
.env
.env.local
.env.*.local
*.properties.local

# Arquivos de configuração sensíveis
application-secret.yml
application-secrets.properties
